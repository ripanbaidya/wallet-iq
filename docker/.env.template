# .env.template
# Template for docker-compose.local.yml — full stack containerised.
# Copy this file to .env.local, fill in the secrets marked with <>, and run:
#   docker compose -f docker/docker-compose.local.yml up -d

SERVER_PORT=8080
API_VERSION=v1
SPRING_PROFILES_ACTIVE=dev

APPLICATION_VERSION=1.0.0
APPLICATION_BUILD_NUMBER=1.0.0

# Database
# Do not change DB_HOST — 'postgres' is the Docker service name.
DB_HOST=postgres
DB_PORT=5432
DB_NAME=walletiq
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Hikari Connection Pool
HIKARI_POOL_NAME=WalletIQHikariPool
HIKARI_POOL_MIN_IDLE=2
HIKARI_IDLE_TIMEOUT=600000
HIKARI_MAX_LIFETIME=1800000
HIKARI_POOL_MAX_SIZE=10
HIKARI_CONNECTION_TIMEOUT=30000
HIKARI_LEAK_DETECTION_THRESHOLD=60000

# Redis
# Do not change the host — 'redis' is the Docker service name.
REDIS_URL=redis://:strongPassword@redis:6379
REDIS_SSL_ENABLED=false

# OpenAI
# Get your API key at https://platform.openai.com/api-keys
OPENAI_API_KEY=<your-openai-api-key>
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
PGVECTOR_DIMENSIONS=1536

# Mail (Gmail SMTP)
# MAIL_PASSWORD must be a Gmail App Password, NOT your account password.
# Generate one at https://myaccount.google.com/apppasswords
MAIL_USERNAME=<your-gmail-address>
MAIL_PASSWORD=<your-gmail-app-password>
MAIL_SSL_TRUST=*

# Razorpay
# Replace with live keys for production.
RAZORPAY_KEY_ID=rzp_test_STtxF7zD3d2bmB
RAZORPAY_KEY_SECRET=d3f4ULGJeVKDHvhJmi34VZ18
SUBSCRIPTION_AMOUNT=19900
SUBSCRIPTION_DAYS=30

# CORS
CORS_ORIGIN_LOCAL=http://localhost:5173
CORS_ORIGIN_VERCEL=https://walletiq-eight.vercel.app
CORS_ORIGIN_PRIMARY=https://walletiq.online

